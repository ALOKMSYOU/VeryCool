local function aFi()
    table.clear(fSv)
    local fSv_idx = 1
    for _, s in ipairs(aSv) do
        local p = s.playing or 0 local m = math.max(s.maxPlayers or 1, 1) local pg = s.ping or 999 local r = p / m
        if cF == "All" then fSv[fSv_idx] = s; fSv_idx = fSv_idx + 1
        elseif cF == "Low Ping" then if pg <= 80 then fSv[fSv_idx] = s; fSv_idx = fSv_idx + 1 end
        elseif cF == "Small" then if r < 0.3 then fSv[fSv_idx] = s; fSv_idx = fSv_idx + 1 end
        elseif cF == "Large" then if p < m and p > 0 then fSv[fSv_idx] = s; fSv_idx = fSv_idx + 1 end end
    end
    if cF == "Low Ping" then table.sort(fSv, function(a,b) return (a.ping or 999) < (b.ping or 999) end)
    elseif cF == "Small" then table.sort(fSv, function(a,b) return (a.playing or 0) < (b.playing or 0) end)
