local function createCorner(parent, radius)
    local corner = Instance.new("UICorner", parent); corner.CornerRadius = UDim.new(0, radius or 6); return corner
end

local function createStroke(parent, color, thickness)
    local stroke = Instance.new("UIStroke", parent)
    stroke.Color = color or Theme.Border; stroke.Thickness = thickness or 1; stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return stroke
end

local function applyHover(frame, targetColor)
    local orig = frame.BackgroundColor3
    frame.MouseEnter:Connect(function() TweenService:Create(frame, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play() end)
    frame.MouseLeave:Connect(function() TweenService:Create(frame, TweenInfo.new(0.2), {BackgroundColor3 = orig}):Play() end)
end

local function applyGlitchEffect(object)
    task.spawn(function()
        local origPos = object.Position
        while object.Parent do
            task.wait(math.random(2, 6))
            for i=1, 2 do
                object.Position = origPos + UDim2.new(0, math.random(-2, 2), 0, math.random(-1, 1))
                task.wait(0.05); object.Position = origPos; task.wait(0.05)
            end
        end
    end)
end

