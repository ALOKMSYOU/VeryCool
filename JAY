end)

executeBtn.MouseButton1Click:Connect(function()
    if confirm then confirm = false; searching = false; executeBtn.Text = "EXECUTE INJECTION"; AddLogEntry("Sequence Aborted.", Theme.Error); return end
    if searching then confirm = true; local old = executeBtn.Text; executeBtn.Text = "CONFIRM ABORT?"; AddLogEntry("Awaiting abort confirm...", Theme.Secondary); task.delay(4, function() if executeBtn.Text == "CONFIRM ABORT?" then confirm = false; executeBtn.Text = old end end); return end
    
    searching = true; executeBtn.Text = "ABORT INJECTION"; AddLogEntry("Bypassing firewalls...", Theme.Primary)
    local username = userBox.Text
    local s, userId = pcall(function() return tonumber(username) or Players:GetUserIdFromNameAsync(username) end)
    if not s or not userId then searching = false; executeBtn.Text = "EXECUTE INJECTION"; AddLogEntry("Error: Target ID unresolvable.", Theme.Error); return end
    
    avatarImage.Image = "rbxthumb://type=AvatarHeadShot&id=" .. userId .. "&w=150&h=150"; AddLogEntry("Extracting image hashes...", Theme.Text)
    local thumbnail = getTargetThumbDirect(userId); if thumbnail == "" then searching = false; executeBtn.Text = "EXECUTE INJECTION"; AddLogEntry("Direct Fetch Blocked. Execution halted.", Theme.Error); return end
    
    AddLogEntry("Target Locked: " .. userId, Theme.Primary); AddLogEntry("Scanning active nodes...", Theme.Text)
    local placeId = tonumber(placeBox.Text)
    if placeBox.Text:gsub("%s", "") == "" then placeId = game.PlaceId elseif not placeId then searching = false; executeBtn.Text = "EXECUTE INJECTION"; AddLogEntry("Invalid Place ID.", Theme.Error); return end
    
    local cursor, searched, playersCount = nil, 0, 0
    task.spawn(function()
        while searching do
            local successFetch, result = getServersDirect(placeId, cursor)
            if successFetch and result and result.data then
                local servers = result.data; cursor = result.nextPageCursor
                for index, server in ipairs(servers) do
                    if not searching then break end
                    task.spawn(function()
                        if server.playerTokens and #server.playerTokens > 0 then
                            local sThumb, thumbs = fetchThumbsDirect(server.playerTokens)
                            if sThumb and thumbs then 
                                playersCount = playersCount + #thumbs
                                for _, pTh in ipairs(thumbs) do 
                                    if pTh.imageUrl and pTh.imageUrl == thumbnail then 
                                        searching = false; AddLogEntry("MATCH FOUND! TELEPORTING...", Theme.Primary)
                                        TeleportService:TeleportToPlaceInstance(placeId, server.id, Players.LocalPlayer); return 
                                    end 
                                end 
                            end
                        end
                    end)
                    searched = searched + 1; AddLogEntry(string.format("Nodes: %d | Entities: %d", searched, playersCount), Theme.TextMuted)
                    if index % threads ~= 0 then task.wait() end
                end
                if not cursor then break end
            else AddLogEntry("Rate Limit. Delaying 2s...", Theme.TextMuted); task.wait(2) end
            task.wait()
        end
        if searching then searching = false; executeBtn.Text = "EXECUTE INJECTION"; AddLogEntry("Search exhausted. Target missing.", Theme.Error) end
    end)
end)

