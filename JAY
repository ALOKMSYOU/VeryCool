local function applyFilters()
    filteredServersData = {}
    for _, s in ipairs(allServersData) do
        local playing = s.playing or 0; local maxP = math.max(s.maxPlayers or 1, 1); local ping = s.ping or 999; local ratio = playing / maxP
        if currentFilter == "All" then table.insert(filteredServersData, s)
        elseif currentFilter == "Low Ping" then if ping <= 80 then table.insert(filteredServersData, s) end
        elseif currentFilter == "Small" then if ratio < 0.3 then table.insert(filteredServersData, s) end
        elseif currentFilter == "Large" then if ratio >= 0.75 and playing < maxP then table.insert(filteredServersData, s) end end
    end
    
    if currentFilter == "Low Ping" then table.sort(filteredServersData, function(a,b) return (a.ping or 999) < (b.ping or 999) end)
    elseif currentFilter == "Small" then table.sort(filteredServersData, function(a,b) return (a.playing or 0) < (b.playing or 0) end)
    elseif currentFilter == "Large" then table.sort(filteredServersData, function(a,b) return (a.playing or 0) > (b.playing or 0) end)
    else table.sort(filteredServersData, function(a,b) return (a.playing or 0) > (b.playing or 0) end) end
    renderBrowserPage(1)
end

