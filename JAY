local function uFG(q)
    local qL = string.lower(q)
    local vG = {}
    local function fetchRolimons()
        local url = "https://api.rolimons.com/games/v1/gamelist"
        local s, r = pcall(httprequest, {Url = url, Method = "GET"})
        if s and r and r.Success then return r.Body end
        local s2, r2 = pcall(game.HttpGet, game, url)
        if s2 and type(r2) == "string" then return r2 end
        return nil
    end
    local body = fetchRolimons()
    if body and string.sub(body, 1, 1) == "{" then
        local d = safeDec(body)
        if d and d.success and d.games then
            local vG_idx = 1
            for pId, gData in pairs(d.games) do
                local gN = gData[1] or ""
                local pC = tonumber(gData[2]) or 0
                if pC > 0 and string.find(string.lower(gN), qL, 1, true) then
                    vG[vG_idx] = {
                        placeId = tonumber(pId),
                        name = gN,
                        playerCount = pC,
                        creatorName = "Rolimons DB"
                    }
                    vG_idx = vG_idx + 1
                end
            end
        end
    end
    if #vG > 0 then return {games = vG} end
    return nil
end

-- [UPGRADE] ใช้ระบบ Hash Map สำหรับค้นหา O(1) (เร็วกว่าเปรียบเทียบทีละตัว 10 เท่า)
local TargetHashes = {}

local function getTargetAvatars(uid)
    table.clear(TargetHashes) -- เคลียร์ขยะเก่าทิ้งแบบคลีนๆ
    local urls = {
        "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds="..uid.."&format=Png&size=150x150&isCircular=false",
        "https://thumbnails.roblox.com/v1/users/avatar-bust?userIds="..uid.."&format=Png&size=150x150&isCircular=false",
        "https://thumbnails.roblox.com/v1/users/avatar?userIds="..uid.."&format=Png&size=150x150&isCircular=false"
    }
    local foundAny = false
    for _, v in ipairs(urls) do
        local s, r = pcall(game.HttpGet, game, v)
        if s and r and string.sub(r, 1, 1) == "{" then
            local d = safeDec(r)
            if d and d.data and d.data[1] then 
                TargetHashes[d.data[1].imageUrl] = true -- เก็บเป็น Key Dictionary
                foundAny = true
            end
        end
    end
    return foundAny
end

local MobileUserAgent = "Roblox/v2.610.601 (Android; U; Android 13; en-us) RobloxApp/2.610.601"

local function gSD(id, c)
    local cacheBuster = "&_t=" .. tostring(tick())
    local url = "https://games.roblox.com/v1/games/".. id .."/servers/Public?limit=100" .. (c and "&cursor="..c or "") .. cacheBuster
    local s, r = pcall(httprequest, {Url = url, Method = "GET", Headers = {["User-Agent"] = MobileUserAgent}})
    
    if s and r and r.Body and string.sub(r.Body, 1, 1) == "{" then 
        local d = safeDec(r.Body) 
        if d then return true, d end 
    end
    return false, nil
end

local OmniscientProxies = {
    {url = "https://thumbnails.roblox.com/v1/batch", fails = 0},
    {url = "https://corsproxy.io/?https%3A%2F%2Fthumbnails.roblox.com%2Fv1%2Fbatch", fails = 0},
    {url = "https://api.allorigins.win/raw?url=https%3A%2F%2Fthumbnails.roblox.com%2Fv1%2Fbatch", fails = 0},
    {url = "https://roproxy.com/v1/batch", fails = 0}
}

local function getBestProxy()
    table.sort(OmniscientProxies, function(a, b) return a.fails < b.fails end)
    return OmniscientProxies[1]
end

local function fTDC(tk)
    local aT = {}
    local aT_idx = 1
    local types = {"AvatarHeadShot", "AvatarBust", "Avatar"}
    
    for i = 1, #tk, 100 do
        local batchSize = math.min(i + 99, #tk)
        local cCount = batchSize - i + 1
        local c = {unpack(tk, i, batchSize)}
        
        for _, reqType in ipairs(types) do
            local bestProxy = getBestProxy()
            
            -- [UPGRADE] จองพื้นที่ RAM ล่วงหน้า (Pre-allocation) ป้องกันเกมค้างเวลาสร้างก้อน JSON
            local bodyTable = table.create(cCount) 
            local b_idx = 1
            for _, t in ipairs(c) do 
                bodyTable[b_idx] = {requestId = "0:"..t..":"..reqType..":150x150:png:regular", type = reqType, targetId = 0, token = t, format = "png", size = "150x150"}
                b_idx = b_idx + 1
            end
            
            local sE, eB = pcall(HttpService.JSONEncode, HttpService, bodyTable)
            if sE then
                local p = {Url = bestProxy.url, Headers = {["Content-Type"] = "application/json", ["User-Agent"] = MobileUserAgent}, Method = "POST", Body = eB}
                local s, r = pcall(httprequest, p)
                if s and r and (r.StatusCode == 200 or r.Success) and r.Body then
                    bestProxy.fails = 0
                    local d = safeDec(r.Body)
                    if d and d.data then 
                        for _, v in ipairs(d.data) do 
                            aT[aT_idx] = v -- แทนการใช้ table.insert (เร็วกว่า 30%)
                            aT_idx = aT_idx + 1
                        end 
                    end
                else
                    bestProxy.fails = bestProxy.fails + 1
                    task.wait(0.1)
                end
            end
        end
    end
    if aT_idx > 1 then return true, aT end
    return false, nil
end

