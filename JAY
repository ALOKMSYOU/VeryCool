local function urlE(s)
    if s then
        s = string.gsub(s, "\n", "\r\n")
        s = string.gsub(s, "([^%w %-%_%.%~])", function(c) return string.format("%%%02X", string.byte(c)) end)
        s = string.gsub(s, " ", "+")
    end
    return s
end

