local function aH(f, tc, sc)
    local og = f.BackgroundColor3
    f.MouseEnter:Connect(function() 
        TweenService:Create(f, TweenInfo.new(0.15, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {BackgroundColor3 = tc}):Play() 
        if sc and f:FindFirstChildOfClass("UIStroke") then TweenService:Create(f:FindFirstChildOfClass("UIStroke"), TweenInfo.new(0.15), {Color = sc}):Play() end
    end)
    f.MouseLeave:Connect(function() 
        TweenService:Create(f, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {BackgroundColor3 = og}):Play() 
