local searching, confirm, threads = false, false, 30

local function getTargetThumbDirect(userId)
    local s, r = pcall(function() return game:HttpGet("https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds=" .. userId .. "&format=Png&size=150x150&isCircular=false") end)
    if s and r and r:sub(1,1) == "{" then local data = safeJSONDecode(r); if data and data.data and data.data[1] then return data.data[1].imageUrl end end
    return ""
end
local function getServersDirect(id, cursor)
    local fullurl = "https://games.roblox.com/v1/games/".. id .."/servers/Public?limit=100" .. (cursor and "&cursor="..cursor or "")
    local s, r = pcall(function() return game:HttpGet(fullurl) end)
    if s and r and r:sub(1,1) == "{" then local dec = safeJSONDecode(r); if dec then return true, dec end end
    return false, nil
end

-- อัปเกรด: ระบบ Chunking สแกนคนได้ทะลุ 100 คนต่อเซิร์ฟเวอร์
local function fetchThumbsDirectChunked(tokens)
    local allThumbs = {}
    for i = 1, #tokens, 100 do
        local chunk = {unpack(tokens, i, math.min(i + 99, #tokens))}
        local payload = { Url = "https://thumbnails.roblox.com/v1/batch", Headers = { ["Content-Type"] = "application/json" }, Method = "POST", Body = {} }
        for _, token in ipairs(chunk) do table.insert(payload.Body, {requestId = "0:"..token..":AvatarHeadshot:150x150:png:regular", type = "AvatarHeadShot", targetId = 0, token = token, format = "png", size = "150x150"}) end
        local sEnc, encBody = pcall(function() return HttpService:JSONEncode(payload.Body) end)
        if sEnc then
            payload.Body = encBody
            local success, result = pcall(function() return httprequest(payload) end)
            if success and result and result.Success then 
                local dec = safeJSONDecode(result.Body)
                if dec and dec.data then for _, v in ipairs(dec.data) do table.insert(allThumbs, v) end end
            end
        end
    end
    if #allThumbs > 0 then return true, allThumbs end
    return false, nil
end

